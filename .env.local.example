# WRIVON API Keys — copy this to .env.local and fill in your keys
# .env.local is gitignored — never commit real keys

# NVIDIA NIM (free tier, no credit card required)
# Get key: https://build.nvidia.com/
NVIDIA_API_KEY=

# Cloudflare Workers AI (free tier)
# Get key & account ID: https://dash.cloudflare.com/
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Groq (free tier, no credit card required)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
